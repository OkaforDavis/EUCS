# ============================================
# ELUGWU UMUOSHIE CO-OPERATIVE SOCIETY LTD
# Environment Configuration
# ============================================

# Application
NODE_ENV=production
PORT=5000
API_VERSION=v1
APP_NAME="EUCS Management System"
APP_URL=https://api.eucs.coop

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eucs_main
DB_USER=eucs_app
DB_PASSWORD=your_secure_database_password
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=20

# Redis Cache & Sessions
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_SESSION_DB=1

# JWT & Security
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=30m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=your_32_character_encryption_key_here

# Session
SESSION_SECRET=your_super_secret_session_key_change_this
SESSION_TIMEOUT=1800000

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000
CSRF_SECRET=your_csrf_secret_key

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=https://eucs.coop,https://www.eucs.coop
CORS_CREDENTIALS=true

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@eucs.coop
SMTP_PASSWORD=your_email_password
EMAIL_FROM="EUCS <noreply@eucs.coop>"

# SMS Provider (Termii, Twilio, etc.)
SMS_PROVIDER=termii
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=EUCS
SMS_API_URL=https://api.ng.termii.com/api/sms/send

# Payment Gateways
# Paystack
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=your_flutterwave_encryption_key
FLUTTERWAVE_WEBHOOK_SECRET=your_flutterwave_webhook_secret

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# Cloud Storage (Optional - AWS S3, Cloudinary, etc.)
CLOUD_STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://api.eucs.coop/auth/google/callback

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_ERROR_FILE=./logs/error.log

# Monitoring (Optional - Sentry, etc.)
SENTRY_DSN=your_sentry_dsn

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=/var/backups/eucs

# System Settings
MIN_WITHDRAWAL_AMOUNT=1000
MAX_WITHDRAWAL_AMOUNT=5000000
DEFAULT_LOAN_INTEREST_RATE=5.0
MAX_LOAN_MULTIPLIER=2.0
MIN_MEMBERSHIP_MONTHS=6

# WhatsApp Groups (Links)
WHATSAPP_GENERAL_GROUP=https://chat.whatsapp.com/your_general_group_link
WHATSAPP_EXECUTIVES_GROUP=https://chat.whatsapp.com/your_executive_group_link
WHATSAPP_STAKEHOLDERS_GROUP=https://chat.whatsapp.com/your_stakeholder_group_link

# Frontend URL
FRONTEND_URL=https://eucs.coop

# Admin
ADMIN_EMAIL=admin@eucs.coop
ADMIN_PHONE=+2348012345678
